---
export const prerender = false;

import { isInputError } from "astro:actions";
import { actions } from "astro:actions";
import { signContactFormTimestamp } from "../lib/contact-form";
import { getEntry, render } from "astro:content";
import { getLocationImage } from "../data/location-images";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("pages", "contact");

if (!entry) {
  throw new Error("Missing contact page content.");
}

const { Content } = await render(entry);
const result = Astro.getActionResult(actions.requestDates);
const fieldErrors = isInputError(result?.error) ? result.error.fields : {};
const formError = result?.error && !isInputError(result.error) ? result.error.message : "";
const successMessage = result?.data?.message ?? "";
const formStartedAt = Date.now().toString();
const formToken = signContactFormTimestamp(formStartedAt);
const hasFieldErrors = Object.keys(fieldErrors).length > 0;
const propertyMap = getLocationImage("property");
const cottages = [
  "Marconi",
  "Big Guilda",
  "Pretty Home",
  "Cones",
  "Oversea",
  "Sandy Scot",
  "Summer Salt",
  "Dunes",
  "Pines",
  "Sands",
  "New Cabin",
  "Little Guilda",
  "Camera",
  "The Captain",
];
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  seoTitle={entry.data.seoTitle ?? "Contact and Request Dates | Cook's by the Ocean"}
  seoDescription={
    entry.data.seoDescription ??
    "Email Cook's by the Ocean or send a request for dates for a weekly cottage stay in South Wellfleet."
  }
  ogImage={entry.data.ogImage ?? propertyMap.fallback.src}
  ogImageAlt="Historic property map of Cook's by the Ocean."
>
  <section class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="space-y-6">
      <p class="eyebrow">Contact / Request Dates</p>
      <h1 class="page-title">Contact and Request Dates</h1>
      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </div>

    <div class="space-y-6">
      {
        successMessage && (
          <section
            class="rounded-[0.85rem] border border-[rgba(79,111,86,0.18)] bg-[rgba(232,241,232,0.9)] p-6 text-[var(--color-ink)]"
            role="status"
            aria-live="polite"
          >
            <h2 class="section-title">Request Sent</h2>
            <p class="mt-3 text-[var(--color-muted)]">{successMessage}</p>
          </section>
        )
      }

      {
        formError && (
          <section
            class="rounded-[0.85rem] border border-[rgba(146,73,54,0.16)] bg-[rgba(250,239,233,0.92)] p-6 text-[var(--color-ink)]"
            role="alert"
            aria-live="assertive"
          >
            <h2 class="section-title">Unable to Send</h2>
            <p class="mt-3 text-[var(--color-muted)]">{formError}</p>
          </section>
        )
      }

      <section class="rounded-[0.85rem] border border-[rgba(34,52,67,0.12)] bg-white/85 p-6 shadow-[0_18px_45px_rgba(34,52,67,0.08)]">
        <div class="space-y-3">
          <p class="eyebrow">Request Dates</p>
          <h2 class="section-title">Send an Availability Request</h2>
          <p class="text-[var(--color-muted)]" id="request-form-help">
            Weekly rentals remain Saturday to Saturday. If you know which cottage
            you are considering, include it here.
          </p>
        </div>

        <form
          method="POST"
          action={actions.requestDates}
          class="mt-6 space-y-5"
          aria-describedby={hasFieldErrors ? "request-form-help request-form-errors" : "request-form-help"}
        >
          <input type="hidden" name="formStartedAt" value={formStartedAt} />
          <input type="hidden" name="formToken" value={formToken} />

          <div class="contact-honeypot" aria-hidden="true">
            <label for="website">Website</label>
            <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          {hasFieldErrors && (
            <p
              id="request-form-errors"
              class="rounded-[0.7rem] border border-[rgba(146,73,54,0.16)] bg-[rgba(250,239,233,0.92)] px-4 py-3 text-sm text-[var(--color-ink)]"
              role="alert"
            >
              Please correct the highlighted fields and try again.
            </p>
          )}

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="contact-field">
              <span class="contact-label">Name</span>
              <input
                class="contact-input"
                type="text"
                name="name"
                autocomplete="name"
                required
                aria-invalid={fieldErrors.name ? "true" : "false"}
                aria-describedby={fieldErrors.name ? "name-error" : undefined}
              />
              {fieldErrors.name && <span class="contact-error" id="name-error">{fieldErrors.name[0]}</span>}
            </label>

            <label class="contact-field">
              <span class="contact-label">Email</span>
              <input
                class="contact-input"
                type="email"
                name="email"
                autocomplete="email"
                required
                aria-invalid={fieldErrors.email ? "true" : "false"}
                aria-describedby={fieldErrors.email ? "email-error" : undefined}
              />
              {fieldErrors.email && <span class="contact-error" id="email-error">{fieldErrors.email[0]}</span>}
            </label>
          </div>

          <div class="grid gap-5 sm:grid-cols-[1.2fr_0.8fr]">
            <label class="contact-field">
              <span class="contact-label">Cottage</span>
              <select
                class="contact-input"
                name="cottage"
                aria-invalid={fieldErrors.cottage ? "true" : "false"}
                aria-describedby={fieldErrors.cottage ? "cottage-error" : undefined}
              >
                <option value="">No preference yet</option>
                {cottages.map((cottage) => <option value={cottage}>{cottage}</option>)}
              </select>
              {fieldErrors.cottage && <span class="contact-error" id="cottage-error">{fieldErrors.cottage[0]}</span>}
            </label>

            <label class="contact-field">
              <span class="contact-label">Guests</span>
              <input
                class="contact-input"
                type="text"
                name="partySize"
                inputmode="numeric"
                aria-invalid={fieldErrors.partySize ? "true" : "false"}
                aria-describedby={fieldErrors.partySize ? "party-size-error" : undefined}
              />
              {fieldErrors.partySize && (
                <span class="contact-error" id="party-size-error">{fieldErrors.partySize[0]}</span>
              )}
            </label>
          </div>

          <label class="contact-field">
            <span class="contact-label">Preferred dates</span>
            <input
              class="contact-input"
              type="text"
              name="preferredDates"
              placeholder="Example: July 11 to July 18"
              required
              aria-invalid={fieldErrors.preferredDates ? "true" : "false"}
              aria-describedby={fieldErrors.preferredDates ? "preferred-dates-error" : undefined}
            />
            {fieldErrors.preferredDates && (
              <span class="contact-error" id="preferred-dates-error">{fieldErrors.preferredDates[0]}</span>
            )}
          </label>

          <label class="contact-field">
            <span class="contact-label">Message</span>
            <textarea
              class="contact-input min-h-36 resize-y"
              name="message"
              placeholder="Anything else that would help narrow the search."
              aria-invalid={fieldErrors.message ? "true" : "false"}
              aria-describedby={fieldErrors.message ? "message-error" : undefined}
            />
            {fieldErrors.message && <span class="contact-error" id="message-error">{fieldErrors.message[0]}</span>}
          </label>

          <button class="button-primary" type="submit">Send Request</button>
        </form>
      </section>

      <section class="rounded-[0.85rem] border border-[rgba(34,52,67,0.12)] bg-white/82 p-6">
        <h2 class="section-title">Current Contact Details</h2>
        <dl class="mt-4 space-y-4 text-[var(--color-muted)]">
          <div>
            <dt class="font-semibold text-[var(--color-ink)]">Email</dt>
            <dd class="mt-1">
              <a class="text-[var(--color-sea)] underline decoration-[rgba(84,114,136,0.35)] underline-offset-4" href="mailto:cooksbytheocean@gmail.com">
                cooksbytheocean@gmail.com
              </a>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-[var(--color-ink)]">Mailing Address</dt>
            <dd class="mt-1">PO Box 237, South Wellfleet, MA 02663</dd>
          </div>
          <div>
            <dt class="font-semibold text-[var(--color-ink)]">Rental Rhythm</dt>
            <dd class="mt-1">Weekly rentals, Saturday to Saturday.</dd>
          </div>
        </dl>
      </section>

      <section class="rounded-[0.85rem] border border-dashed border-[rgba(34,52,67,0.18)] bg-[rgba(244,239,229,0.7)] p-6">
        <h2 class="section-title">What to Include</h2>
        <p class="mt-4 text-[var(--color-muted)]">
          If you are writing about a stay, the most helpful details are your
          preferred dates, the cottage you are considering, the size of your
          group, and anything else
          that would help narrow the search.
        </p>
      </section>
    </div>
  </section>
</Layout>
