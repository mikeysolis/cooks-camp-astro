---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("pages", "location");

if (!entry) {
  throw new Error("Missing location page content.");
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <section class="space-y-8">
    <p class="eyebrow">Directions</p>
    <h1 class="page-title">{entry.data.title}</h1>
    <div class="prose prose-lg max-w-3xl">
      <Content />
    </div>
    <figure class="max-w-3xl overflow-hidden rounded-[1rem] border border-[rgba(34,52,67,0.12)] bg-white/80 shadow-[0_18px_45px_rgba(34,52,67,0.08)]">
      <img
        src="/images/historic/cooks-property-map.jpg"
        alt="Historic map of Cook's by the Ocean showing the cottages and the layout of the property."
        width="600"
        height="456"
        class="w-full object-cover"
        loading="lazy"
      />
      <figcaption class="px-5 py-4 text-sm leading-6 text-[var(--color-muted)]">
        A historic map of the cottages and the bluff at Cook&apos;s by the Ocean.
      </figcaption>
    </figure>
    <figure class="max-w-3xl overflow-hidden rounded-[1rem] border border-[rgba(34,52,67,0.12)] bg-white/80 shadow-[0_18px_45px_rgba(34,52,67,0.08)]">
      <img
        src="/images/historic/cape-cod-map.png"
        alt="Regional map of Cape Cod for orientation before following the directions to Cook's by the Ocean."
        width="700"
        height="467"
        class="w-full object-cover"
        loading="lazy"
      />
      <figcaption class="px-5 py-4 text-sm leading-6 text-[var(--color-muted)]">
        A regional view of Cape Cod before you continue toward South Wellfleet and LeCount Hollow Road.
      </figcaption>
    </figure>
  </section>
</Layout>
