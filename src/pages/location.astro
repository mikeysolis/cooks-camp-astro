---
import { getEntry, render } from "astro:content";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { getLocationImage } from "../data/location-images";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("pages", "location");

if (!entry) {
  throw new Error("Missing location page content.");
}

const { Content } = await render(entry);
const propertyMap = getLocationImage("property");
const capeCodMap = getLocationImage("capeCod");
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  seoTitle={entry.data.seoTitle ?? "Directions | Cook's by the Ocean"}
  seoDescription={
    entry.data.seoDescription ??
    "Directions to Cook's by the Ocean in South Wellfleet, near LeCount Hollow Beach."
  }
  ogImage={entry.data.ogImage ?? capeCodMap.fallback.src}
  ogImageAlt="Regional Cape Cod map for Cook's by the Ocean directions."
>
  <section class="space-y-8">
    <p class="eyebrow">Directions</p>
    <h1 class="page-title">Directions to Cook's by the Ocean</h1>
    <div class="prose prose-lg max-w-3xl">
      <Content />
    </div>
    <div class="flex flex-wrap gap-3">
      <a class="button-secondary" href="/cottages">Browse the Cottages</a>
      <a class="button-secondary" href="/contact">Request Dates</a>
    </div>
    <figure class="max-w-3xl overflow-hidden rounded-[1rem] border border-[rgba(34,52,67,0.12)] bg-white/80 shadow-[0_18px_45px_rgba(34,52,67,0.08)]">
      <ResponsiveImage
        image={propertyMap}
        sizes="(min-width: 1280px) 960px, (min-width: 1024px) 75vw, 100vw"
        pictureClass="block"
        imgClass="w-full object-cover"
        loading="lazy"
      />
      <figcaption class="px-5 py-4 text-sm leading-6 text-[var(--color-muted)]">
        A historic map of the cottages and the bluff at Cook&apos;s by the Ocean.
      </figcaption>
    </figure>
    <figure class="max-w-3xl overflow-hidden rounded-[1rem] border border-[rgba(34,52,67,0.12)] bg-white/80 shadow-[0_18px_45px_rgba(34,52,67,0.08)]">
      <ResponsiveImage
        image={capeCodMap}
        sizes="(min-width: 1280px) 960px, (min-width: 1024px) 75vw, 100vw"
        pictureClass="block"
        imgClass="w-full object-cover"
        loading="lazy"
      />
      <figcaption class="px-5 py-4 text-sm leading-6 text-[var(--color-muted)]">
        A regional view of Cape Cod before you continue toward South Wellfleet and LeCount Hollow Road.
      </figcaption>
    </figure>
    <div class="flex flex-wrap gap-3">
      <a class="button-secondary" href="/contact">Contact and Request Dates</a>
      <a class="button-secondary" href="/about">About Cook&apos;s by the Ocean</a>
    </div>
  </section>
</Layout>
