---
import { getCollection } from "astro:content";
import CottageCard from "../components/CottageCard.astro";
import { getCottagePhotoSet } from "../data/cottage-photos";
import Layout from "../layouts/Layout.astro";

const cottages = (await getCollection("cottages")).sort((a, b) => {
  const left = a.data.order ?? 999;
  const right = b.data.order ?? 999;
  return left - right;
});

const featuredCottages = cottages.filter((entry) => entry.data.featured).slice(0, 4);
---

<Layout
  title="Cook's by the Ocean"
  description="Fourteen cottages above the Atlantic in South Wellfleet, available for weekly rental."
>
  <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
    <div class="space-y-6">
      <p class="eyebrow">South Wellfleet, Cape Cod</p>
      <h1 class="font-display text-6xl leading-[0.95] text-[var(--color-ink)] sm:text-7xl">
        Cook's by the Ocean.
        <span class="text-[var(--color-sea)]">Happy Birthday Dad!</span>
        <!-- <span class="text-[var(--color-sea)]">Over 85 years on the dunes above the Atlantic.</span> -->
      </h1>
      <p class="max-w-2xl text-lg leading-8 text-[var(--color-muted)]">
        In continuous operation by the same family for over 85 years, Cook's
        remains a place where simplicity and peace define both the time you
        spend here and the memories you take away. Fourteen cottages sit above
        the Atlantic in South Wellfleet, just south of LeCount Hollow Beach.
      </p>
      <div class="flex flex-wrap gap-3">
        <a class="button-primary" href="/cottages">Browse Cottages</a>
        <a class="button-secondary" href="/contact">Request Dates</a>
      </div>
    </div>

    <div class="overflow-hidden rounded-[2rem] border border-[rgba(34,52,67,0.14)] bg-[linear-gradient(160deg,rgba(253,251,246,0.92),rgba(215,205,184,0.86))] p-8 shadow-[0_24px_65px_rgba(34,52,67,0.10)]">
      <div class="space-y-5">
        <h2 class="font-display text-4xl text-[var(--color-ink)]">At a Glance</h2>
        <p class="text-[var(--color-muted)]">
          To check availability or make reservations, send an email with the
          cottage you have in mind and the dates you are considering.
        </p>
        <div>
          <a class="button-secondary" href="/contact">Contact Us</a>
        </div>
        <dl class="grid gap-4 text-sm text-[var(--color-muted)]">
          <div class="rounded-[1.25rem] bg-white/70 p-4">
            <dt class="font-semibold text-[var(--color-ink)]">By the Week</dt>
            <dd class="mt-1">All rentals are by the week, Saturday to Saturday.</dd>
          </div>
          <div class="rounded-[1.25rem] bg-white/70 p-4">
            <dt class="font-semibold text-[var(--color-ink)]">In Each Cottage</dt>
            <dd class="mt-1">Full kitchen, half bath, outdoor shower, WiFi, and Rinnai propane heater.</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="mt-14 space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="space-y-3">
        <p class="eyebrow">Featured Cottages</p>
        <h2 class="section-title">A few places to begin.</h2>
      </div>
      <p class="max-w-2xl text-[var(--color-muted)]">Large, medium, and studio cottages.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {
        featuredCottages.map((cottage) => (
          <CottageCard
            href={`/cottages/${cottage.id}`}
            title={cottage.data.title}
            description={cottage.data.description}
            sleeps={cottage.data.sleeps}
            bedrooms={cottage.data.bedrooms}
            bathrooms={cottage.data.bathrooms}
            category={cottage.data.category}
            hero={getCottagePhotoSet(cottage.id).hero.src}
          />
        ))
      }
    </div>
  </section>

  <section class="mt-14 grid gap-6 md:grid-cols-3">
    <a class="feature-card" href="/photos">
      <p class="eyebrow">Photos</p>
      <h2 class="feature-title">Inside the cottages.</h2>
      <p class="feature-copy">View the interiors, light, and the shape of each cottage.</p>
    </a>
    <a class="feature-card" href="/legacy">
      <p class="eyebrow">Historic Gallery</p>
      <h2 class="feature-title">Historical photographs of Cook's.</h2>
      <p class="feature-copy">Historical photos of the camps, the beach, and the earlier years at Cook's.</p>
    </a>
    <a class="feature-card" href="/contact">
      <p class="eyebrow">Contact</p>
      <h2 class="feature-title">Availability & Reservations.</h2>
      <p class="feature-copy">Tell us your dates, the cottage you have in mind, and anything else that would help narrow the search.</p>
    </a>
  </section>
</Layout>
