---
import PhotoSwipeGallery from "../../components/PhotoSwipeGallery.astro";
import { legacyCategories } from "../../data/legacy";
import { getLegacyCategoryGallery } from "../../data/legacy-gallery";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return legacyCategories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const gallery = getLegacyCategoryGallery(category.slug);
---

<Layout title={category.title} description={category.description}>
  <section class="space-y-8">
    <div class="space-y-4">
      <p class="eyebrow">Historic Gallery</p>
      <h1 class="page-title">{category.title}</h1>
      <p class="page-copy max-w-3xl">{category.description}</p>
    </div>

    {
      gallery.groups.map((group) => (
        <section class="space-y-5">
          <div class="space-y-3">
            <h2 class="section-title">{group.title}</h2>
            {group.description && (
              <p class="max-w-3xl text-[var(--color-muted)]">{group.description}</p>
            )}
          </div>

          <PhotoSwipeGallery
            galleryId={`legacy-gallery-${category.slug}-${group.title.toLowerCase().replaceAll(/[^a-z0-9]+/g, "-")}`}
            items={group.items.map((item) => ({
              full: item.full,
              fullWidth: item.fullWidth,
              fullHeight: item.fullHeight,
              thumb: item.thumb,
              thumbWidth: item.thumbWidth,
              thumbHeight: item.thumbHeight,
              alt: item.alt,
              caption: item.caption,
            }))}
            variant="archive"
            showCaptions={true}
          />
        </section>
      ))
    }
  </section>
</Layout>
