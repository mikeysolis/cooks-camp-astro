---
import { getEntry, render } from "astro:content";
import { legacyCategoriesWithGallery } from "../../data/legacy-gallery";
import Layout from "../../layouts/Layout.astro";

const entry = await getEntry("pages", "legacy");

if (!entry) {
  throw new Error("Missing legacy page content.");
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <section class="space-y-8">
    <div class="space-y-4">
      <p class="eyebrow">Historic Gallery</p>
      <h1 class="page-title">{entry.data.title}</h1>
      <div class="prose prose-lg max-w-3xl">
        <Content />
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {
        legacyCategoriesWithGallery.map((category) => (
          <a
            href={`/legacy/${category.slug}`}
            class="group overflow-hidden rounded-[1rem] border border-[rgba(112,95,70,0.22)] bg-[linear-gradient(180deg,rgba(249,245,238,0.94),rgba(236,228,214,0.94))] p-3 transition duration-200 hover:-translate-y-px hover:shadow-[0_16px_36px_rgba(34,52,67,0.07)]"
          >
            <div class="overflow-hidden rounded-[0.7rem] border border-[rgba(112,95,70,0.16)] bg-[rgba(255,255,255,0.75)]">
              <img
                src={category.coverImage}
                alt={`Preview from the ${category.title} archive`}
                class="aspect-[4/3] w-full object-cover transition duration-300 group-hover:scale-[1.01]"
                loading="lazy"
              />
            </div>
            <div class="space-y-3 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="eyebrow">Historic Gallery</p>
                  <h2 class="mt-3 font-display text-3xl text-[var(--color-ink)]">{category.title}</h2>
                </div>
                <span class="rounded-full border border-[rgba(112,95,70,0.18)] bg-white/75 px-3 py-1 text-xs uppercase tracking-[0.22em] text-[var(--color-sea)]">
                  {category.itemCount} images
                </span>
              </div>
              <p class="text-[var(--color-muted)]">{category.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
