---
import { getEntry, render } from "astro:content";
import { legacyCategories } from "../../data/legacy";
import Layout from "../../layouts/Layout.astro";

const entry = await getEntry("pages", "legacy");

if (!entry) {
  throw new Error("Missing legacy page content.");
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <section class="space-y-8">
    <div class="space-y-4">
      <p class="eyebrow">Archive</p>
      <h1 class="page-title">{entry.data.title}</h1>
      <div class="prose prose-lg max-w-3xl">
        <Content />
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {
        legacyCategories.map((category) => (
          <a
            href={`/legacy/${category.slug}`}
            class="rounded-[1.5rem] border border-[rgba(34,52,67,0.12)] bg-white/82 p-6 transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_45px_rgba(34,52,67,0.08)]"
          >
            <p class="eyebrow">Legacy Category</p>
            <h2 class="mt-3 font-display text-3xl text-[var(--color-ink)]">{category.title}</h2>
            <p class="mt-3 text-[var(--color-muted)]">{category.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
