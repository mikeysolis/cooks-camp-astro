---
import { getEntry, render } from "astro:content";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import { legacyCategoriesWithGallery } from "../../data/legacy-gallery";
import Layout from "../../layouts/Layout.astro";

const entry = await getEntry("pages", "legacy");

if (!entry) {
  throw new Error("Missing legacy page content.");
}

const { Content } = await render(entry);
const legacyShareImage = entry.data.ogImage ?? legacyCategoriesWithGallery.find((category) => category.coverImage)?.coverImage?.fallback.src;
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  seoTitle={entry.data.seoTitle ?? "Historic Gallery | Cook's by the Ocean"}
  seoDescription={
    entry.data.seoDescription ??
    "Historic photographs of Cook's, the camps, the beach, and earlier years in South Wellfleet."
  }
  ogImage={legacyShareImage}
  ogImageAlt="Historic photography from Cook's by the Ocean."
>
  <section class="space-y-8">
    <div class="space-y-4">
      <p class="eyebrow">Historic Gallery</p>
      <h1 class="page-title">Historic Photos of Cook's by the Ocean</h1>
      <div class="prose prose-lg max-w-3xl">
        <Content />
      </div>
      <div class="flex flex-wrap gap-3">
        <a class="button-secondary" href="/photos">Current Cottage Photos</a>
        <a class="button-secondary" href="/cottages">Browse the Cottages</a>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {
        legacyCategoriesWithGallery.map((category) => (
          <a
            href={`/legacy/${category.slug}`}
            class="group overflow-hidden rounded-[1rem] border border-[rgba(112,95,70,0.22)] bg-[linear-gradient(180deg,rgba(249,245,238,0.94),rgba(236,228,214,0.94))] p-3 transition duration-200 hover:-translate-y-px hover:shadow-[0_16px_36px_rgba(34,52,67,0.07)]"
          >
            <div class="overflow-hidden rounded-[0.7rem] border border-[rgba(112,95,70,0.16)] bg-[rgba(255,255,255,0.75)]">
              {
                category.coverImage ? (
                  <ResponsiveImage
                    image={category.coverImage}
                    alt={`Preview from the ${category.title} archive`}
                    sizes="(min-width: 1024px) 42vw, 100vw"
                    pictureClass="block"
                    imgClass="aspect-[4/3] w-full object-cover transition duration-300 group-hover:scale-[1.01]"
                    loading="lazy"
                  />
                ) : (
                  <div class="aspect-[4/3] w-full bg-[rgba(255,255,255,0.65)]" aria-hidden="true"></div>
                )
              }
            </div>
            <div class="space-y-3 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="eyebrow">Historic Gallery</p>
                  <h2 class="mt-3 font-display text-3xl text-[var(--color-ink)]">{category.title}</h2>
                </div>
                <span class="rounded-full border border-[rgba(112,95,70,0.18)] bg-white/75 px-3 py-1 text-xs uppercase tracking-[0.22em] text-[var(--color-sea)]">
                  {category.itemCount} images
                </span>
              </div>
              <p class="text-[var(--color-muted)]">{category.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
