---
import { getCollection, getEntry, render } from "astro:content";
import { cottageCategories } from "../data/cottage-categories";
import { getCottagePhotoSet } from "../data/cottage-photos";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("pages", "photos");

if (!entry) {
  throw new Error("Missing photos page content.");
}

const { Content } = await render(entry);
const cottages = (await getCollection("cottages")).sort((a, b) => {
  const left = a.data.order ?? 999;
  const right = b.data.order ?? 999;
  return left - right;
});

const cottagesByCategory = cottages.reduce<Record<string, typeof cottages>>((groups, cottage) => {
  const key = cottage.data.category;
  const current = groups[key] ?? [];
  groups[key] = [...current, cottage];
  return groups;
}, {});
---

<Layout title={entry.data.title} description={entry.data.description}>
  <section class="space-y-8">
    <div class="space-y-4">
      <p class="eyebrow">Modern Photos</p>
      <h1 class="page-title">{entry.data.title}</h1>
      <div class="prose prose-lg max-w-3xl">
        <Content />
      </div>
    </div>

    {
      cottageCategories.map((category) => {
        const entries = cottagesByCategory[category.key] ?? [];

        return (
          <section class="space-y-5">
            <div class="space-y-3">
              <p class="eyebrow">{category.key}</p>
              <h2 class="section-title">{category.title}</h2>
              <p class="max-w-3xl text-[var(--color-muted)]">{category.blurb}</p>
            </div>

            <div class="grid gap-6 md:grid-cols-2">
              {entries.map((cottage) => {
                const photoSet = getCottagePhotoSet(cottage.id);

                return (
                  <a
                    href={`/cottages/${cottage.id}`}
                    class="group overflow-hidden rounded-[0.85rem] border border-[rgba(34,52,67,0.12)] bg-white/85 shadow-[0_14px_36px_rgba(34,52,67,0.07)] transition duration-200 hover:-translate-y-px hover:shadow-[0_18px_42px_rgba(34,52,67,0.09)]"
                  >
                    <img
                      src={photoSet.hero.src}
                      alt={`Current view inside ${cottage.data.title}`}
                      class="aspect-[4/3] h-full w-full object-cover transition duration-300 group-hover:scale-[1.01]"
                      loading="lazy"
                    />
                    <div class="space-y-3 p-5">
                      <div class="flex items-start justify-between gap-3">
                        <h3 class="font-display text-3xl text-[var(--color-ink)]">
                          {cottage.data.title}
                        </h3>
                        <span class="rounded-full border border-[rgba(34,52,67,0.14)] px-3 py-1 text-xs uppercase tracking-[0.25em] text-[var(--color-sea)]">
                          {photoSet.totalPhotos} photos
                        </span>
                      </div>
                      <p class="text-[var(--color-muted)]">{cottage.data.description}</p>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        );
      })
    }
  </section>
</Layout>
