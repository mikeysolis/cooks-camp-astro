---
import { getCollection } from "astro:content";
import { getEntry, render } from "astro:content";
import { cottageCategories } from "../data/cottage-categories";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("pages", "photos");

if (!entry) {
  throw new Error("Missing photos page content.");
}

const { Content } = await render(entry);
const cottages = await getCollection("cottages");
const countsByCategory = cottages.reduce<Record<string, number>>((counts, cottage) => {
  const key = cottage.data.category;
  counts[key] = (counts[key] ?? 0) + 1;
  return counts;
}, {});
---

<Layout title={entry.data.title} description={entry.data.description}>
  <section class="space-y-8">
    <div class="space-y-4">
      <p class="eyebrow">Modern Photos</p>
      <h1 class="page-title">{entry.data.title}</h1>
      <div class="prose prose-lg max-w-3xl">
        <Content />
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        cottageCategories.map((category) => (
          <article class="rounded-[1.5rem] border border-[rgba(34,52,67,0.12)] bg-white/80 p-5">
            <div class="aspect-[4/3] rounded-[1.25rem] bg-[linear-gradient(145deg,rgba(84,114,136,0.15),rgba(232,225,209,0.9))]" />
            <h2 class="mt-4 font-display text-2xl text-[var(--color-ink)]">
              {category.title}
            </h2>
            <p class="mt-2 text-[var(--color-muted)]">
              {countsByCategory[category.key] ?? 0} cottages will feed
              this group once the modern web-ready photo sets are exported.
            </p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
