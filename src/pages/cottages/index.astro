---
import { getCollection } from "astro:content";
import CottageCard from "../../components/CottageCard.astro";
import { cottageCategories } from "../../data/cottage-categories";
import Layout from "../../layouts/Layout.astro";

const cottages = (await getCollection("cottages")).sort((a, b) => {
  const left = a.data.order ?? 999;
  const right = b.data.order ?? 999;
  return left - right;
});

const cottagesByCategory = cottages.reduce<
  Partial<Record<"large" | "medium" | "small", typeof cottages>>
>((groups, entry) => {
  const key = entry.data.category;
  const current = groups[key] ?? [];
  groups[key] = [...current, entry];
  return groups;
}, {});
---

<Layout
  title="Cottages"
  description="Browse the cottages at Cook's by the Ocean by size and character."
>
  <section class="space-y-10">
    <div class="space-y-4">
      <p class="eyebrow">Choose a Cottage</p>
      <h1 class="page-title">A calm way to browse the camps.</h1>
      <p class="page-copy max-w-3xl">
        The cottages remain grouped the way the current site presents them:
        large, medium, and small studio cottages. The new version simply makes
        that structure easier to scan and easier to use on modern screens.
      </p>
    </div>

    {
      cottageCategories.map((category) => {
        const entries = cottagesByCategory[category.key] ?? [];

        return (
          <section class="space-y-5">
            <div class="space-y-3">
              <p class="eyebrow">{category.key}</p>
              <h2 class="section-title">{category.title}</h2>
              <p class="max-w-3xl text-[var(--color-muted)]">{category.blurb}</p>
            </div>
            <div class="grid gap-6 lg:grid-cols-2">
              {entries.map((cottage) => (
                <CottageCard
                  href={`/cottages/${cottage.id}`}
                  title={cottage.data.title}
                  description={cottage.data.description}
                  sleeps={cottage.data.sleeps}
                  bedrooms={cottage.data.bedrooms}
                  bathrooms={cottage.data.bathrooms}
                  category={cottage.data.category}
                  hero={cottage.data.hero}
                />
              ))}
            </div>
          </section>
        );
      })
    }
  </section>
</Layout>
