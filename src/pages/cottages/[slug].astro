---
import { getCollection, render } from "astro:content";
import PhotoSwipeGallery from "../../components/PhotoSwipeGallery.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import { getCottagePhotoSet } from "../../data/cottage-photos";
import { getHistoricCottageMedia } from "../../data/historic-cottage-media";
import Layout from "../../layouts/Layout.astro";
import { buildVacationRentalStructuredData } from "../../lib/seo";

export async function getStaticPaths() {
  const cottages = await getCollection("cottages");

  return cottages.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const photoSet = getCottagePhotoSet(entry.id);
const historicMedia = getHistoricCottageMedia(entry.id);
const categoryLabel = {
  large: "two bedroom cottage",
  medium: "one bedroom cottage",
  small: "studio cottage",
}[entry.data.category];
const seoTitle = entry.data.seoTitle ?? `${entry.data.title} Cottage in South Wellfleet`;
const seoDescription = entry.data.seoDescription ?? entry.data.description;
const ogImage = entry.data.ogImage ?? photoSet.hero.fallback.src;
const ogImageAlt = `${entry.data.title} at Cook's by the Ocean in South Wellfleet.`;
const structuredData = buildVacationRentalStructuredData({
  amenities: entry.data.amenities,
  bedrooms: entry.data.bedrooms,
  description: seoDescription,
  image: ogImage,
  name: entry.data.title,
  pathname: Astro.url.pathname,
  sleeps: entry.data.sleeps,
});
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  structuredData={structuredData}
>
  <article class="space-y-10">
    <section class="overflow-hidden rounded-[1rem] border border-[rgba(34,52,67,0.12)] bg-white/85 shadow-[0_20px_60px_rgba(34,52,67,0.08)]">
      <div class="grid gap-0 lg:grid-cols-[1.35fr_0.95fr]">
        <div class="min-h-[18rem] bg-[var(--color-mist)]">
          <ResponsiveImage
            image={photoSet.hero}
            sizes="(min-width: 1024px) 58vw, 100vw"
            pictureClass="block h-full w-full"
            imgClass="h-full w-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <div class="flex flex-col justify-between gap-8 p-8">
          <div class="space-y-4">
            <p class="eyebrow">{categoryLabel}</p>
            <h1 class="page-title">{entry.data.title}</h1>
            <p class="page-copy">{entry.data.description}</p>
          </div>
          <dl class="grid grid-cols-2 gap-4 rounded-[0.85rem] border border-[rgba(34,52,67,0.1)] bg-[rgba(244,239,229,0.7)] p-5 text-sm">
            <div>
              <dt class="text-[var(--color-muted)]">Sleeps</dt>
              <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">{entry.data.sleeps}</dd>
            </div>
            <div>
              <dt class="text-[var(--color-muted)]">Bedrooms</dt>
              <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">
                {entry.data.bedrooms === 0 ? "Studio" : entry.data.bedrooms}
              </dd>
            </div>
            <div>
              <dt class="text-[var(--color-muted)]">Bath</dt>
              <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">{entry.data.bathrooms}</dd>
            </div>
            <div>
              <dt class="text-[var(--color-muted)]">Category</dt>
              <dd class="mt-1 text-lg font-semibold capitalize text-[var(--color-ink)]">{entry.data.category}</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <section class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="space-y-5">
        <h2 class="section-title">Description</h2>
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      </div>

      <aside class="space-y-6">
        <section class="rounded-[0.85rem] border border-[rgba(34,52,67,0.12)] bg-white/80 p-6">
          <h2 class="section-title">In Each Cottage</h2>
          <ul class="mt-4 space-y-3 text-[var(--color-muted)]">
            {entry.data.amenities.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="rounded-[0.85rem] border border-[rgba(34,52,67,0.12)] bg-[rgba(84,114,136,0.08)] p-6">
          <h2 class="section-title">Request Dates</h2>
          <p class="mt-4 text-[var(--color-muted)]">
            To check availability or make reservations, use the request form or
            send us an email at cooksbytheocean@gmail.com.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a class="button-primary" href="/contact">Request Dates</a>
            <a class="button-secondary" href="mailto:cooksbytheocean@gmail.com">
              Email Cook&apos;s
            </a>
          </div>
        </section>

        <section class="rounded-[0.85rem] border border-[rgba(34,52,67,0.12)] bg-white/80 p-6">
          <h2 class="section-title">Related</h2>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="button-secondary" href="/cottages">All Cottages</a>
            <a class="button-secondary" href="/location">Directions to Cook&apos;s</a>
            <a class="button-secondary" href="/legacy">Historic Photos</a>
          </div>
        </section>
      </aside>
    </section>

    <section class="space-y-5">
      <div class="space-y-2">
        <p class="eyebrow">Current Photography</p>
        <h2 class="section-title">Inside {entry.data.title}</h2>
      </div>

      {
        photoSet.photos.length > 0 ? (
          <PhotoSwipeGallery
            galleryId={`cottage-gallery-${entry.id}`}
            items={photoSet.photos.map((photo) => ({
              full: photo.full,
              thumb: photo.thumb,
              alt: photo.alt,
              caption: photo.caption,
            }))}
          />
        ) : (
          <section class="rounded-[0.85rem] border border-dashed border-[rgba(34,52,67,0.18)] bg-[rgba(244,239,229,0.65)] p-6">
            <p class="text-[var(--color-muted)]">
              Current photography for this cottage is still being prepared.
            </p>
          </section>
        )
      }
    </section>

    {
      (historicMedia.photos.length > 0 || historicMedia.map) && (
        <section class="space-y-8">
          <div class="space-y-2">
            <p class="eyebrow">Historic Photos</p>
            <h2 class="section-title">Earlier views of {entry.data.title}</h2>
          </div>

          {historicMedia.photos.length > 0 && (
            <PhotoSwipeGallery
              galleryId={`historic-cottage-gallery-${entry.id}`}
              items={historicMedia.photos}
              variant="archive"
              showCaptions={true}
            />
          )}

          {historicMedia.map && (
            <figure class="max-w-3xl overflow-hidden rounded-[1rem] border border-[rgba(112,95,70,0.2)] bg-[linear-gradient(180deg,rgba(249,245,238,0.96),rgba(236,228,214,0.94))] p-3 shadow-[0_16px_40px_rgba(34,52,67,0.08)]">
              <div class="overflow-hidden rounded-[0.6rem] border border-[rgba(112,95,70,0.14)] bg-white/85">
                <ResponsiveImage
                  image={historicMedia.map}
                  sizes="(min-width: 1280px) 960px, (min-width: 1024px) 75vw, 100vw"
                  pictureClass="block"
                  imgClass="w-full object-cover"
                  loading="lazy"
                />
              </div>
              <figcaption class="px-1 pb-1 pt-4 text-sm leading-6 text-[var(--color-muted)]">
                Historic cottage map.
              </figcaption>
            </figure>
          )}
        </section>
      )
    }
  </article>
</Layout>
