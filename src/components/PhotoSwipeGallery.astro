---
import ResponsiveImage from "./ResponsiveImage.astro";
import type { ResponsiveImageAsset } from "../data/responsive-image";

type GalleryImageAsset = string | ResponsiveImageAsset;

interface GalleryItem {
  full: GalleryImageAsset;
  fullWidth?: number;
  fullHeight?: number;
  thumb: GalleryImageAsset;
  thumbWidth?: number;
  thumbHeight?: number;
  alt: string;
  caption?: string;
}

interface Props {
  galleryId: string;
  items: GalleryItem[];
  variant?: "modern" | "archive";
  showCaptions?: boolean;
  thumbSizes?: string;
}

const {
  galleryId,
  items,
  variant = "modern",
  showCaptions = false,
  thumbSizes,
} = Astro.props;
const galleryClass =
  variant === "archive"
    ? "pswp-gallery grid gap-5 sm:grid-cols-2 xl:grid-cols-3"
    : "pswp-gallery grid gap-4 sm:grid-cols-2 xl:grid-cols-3";
const resolvedThumbSizes =
  thumbSizes ?? "(min-width: 1280px) 26vw, (min-width: 640px) 50vw, 100vw";

function isResponsiveImageAsset(value: GalleryImageAsset): value is ResponsiveImageAsset {
  return typeof value === "object" && value !== null && "formats" in value && "fallback" in value;
}

function getPreferredSource(value: GalleryImageAsset) {
  if (!isResponsiveImageAsset(value)) {
    return value;
  }

  return (
    value.formats.webp?.at(-1)?.src ??
    value.formats.jpg?.at(-1)?.src ??
    value.formats.avif?.at(-1)?.src ??
    value.fallback.src
  );
}

function getImageDimensions(
  value: GalleryImageAsset,
  fallbackWidth?: number,
  fallbackHeight?: number,
) {
  if (isResponsiveImageAsset(value)) {
    return {
      width: value.width,
      height: value.height,
    };
  }

  return {
    width: fallbackWidth ?? 0,
    height: fallbackHeight ?? 0,
  };
}

const preparedItems = items.map((item, index) => ({
  ...item,
  index,
  fullSource: getPreferredSource(item.full),
  fullDimensions: getImageDimensions(item.full, item.fullWidth, item.fullHeight),
  thumbDimensions: getImageDimensions(item.thumb, item.thumbWidth, item.thumbHeight),
}));
---

<div id={galleryId} class={galleryClass}>
  {
    preparedItems.map((item) => (
      <figure
        class:list={[
          variant === "archive"
            ? "overflow-hidden rounded-[0.85rem] border border-[rgba(112,95,70,0.2)] bg-[linear-gradient(180deg,rgba(249,245,238,0.96),rgba(236,228,214,0.94))] p-3 shadow-[0_16px_40px_rgba(34,52,67,0.08)]"
            : "overflow-hidden rounded-[0.85rem] border border-[rgba(34,52,67,0.12)] bg-white/85 shadow-[0_18px_45px_rgba(34,52,67,0.08)]",
        ]}
      >
        <a
          href={item.fullSource}
          data-pswp-width={item.fullDimensions.width}
          data-pswp-height={item.fullDimensions.height}
          data-pswp-caption={item.caption ?? item.alt}
          aria-label={item.caption
            ? `Open image ${item.index + 1} of ${items.length}: ${item.caption}`
            : `Open image ${item.index + 1} of ${items.length}: ${item.alt}`}
          class:list={[
            "block overflow-hidden",
            variant === "archive"
              ? "rounded-[0.6rem] border border-[rgba(112,95,70,0.14)] bg-white/85"
              : "",
          ]}
        >
          {isResponsiveImageAsset(item.thumb) ? (
            <ResponsiveImage
              image={item.thumb}
              sizes={resolvedThumbSizes}
              pictureClass="block"
              imgClass="aspect-[4/3] w-full object-cover transition duration-300 hover:scale-[1.01]"
              alt={item.alt}
              loading="lazy"
            />
          ) : (
            <img
              src={item.thumb}
              width={item.thumbDimensions.width}
              height={item.thumbDimensions.height}
              alt={item.alt}
              class="aspect-[4/3] w-full object-cover transition duration-300 hover:scale-[1.01]"
              loading="lazy"
            />
          )}
        </a>
        {showCaptions && item.caption && (
          <figcaption class="px-1 pb-1 pt-4 text-sm leading-6 text-[var(--color-muted)]">
            {item.caption}
          </figcaption>
        )}
      </figure>
    ))
  }
</div>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";

  function initializePhotoSwipeGalleries() {
    const galleryElements = document.querySelectorAll(".pswp-gallery");

    galleryElements.forEach((galleryElement) => {
      if (!(galleryElement instanceof HTMLElement) || !galleryElement.id) {
        return;
      }

      if (galleryElement.dataset.pswpBound === "true") {
        return;
      }

      galleryElement.dataset.pswpBound = "true";

      const lightbox = new PhotoSwipeLightbox({
        gallery: `#${galleryElement.id}`,
        children: "a",
        pswpModule: () => import("photoswipe"),
        showHideAnimationType: "zoom",
        bgOpacity: 0.92,
        paddingFn: () => ({ top: 36, bottom: 88, left: 24, right: 24 }),
      });

      lightbox.init();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePhotoSwipeGalleries, {
      once: true,
    });
  } else {
    initializePhotoSwipeGalleries();
  }
</script>
