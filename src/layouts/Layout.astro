---
import "../styles/global.css";
import { navigationItems } from "../data/navigation";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Cook's by the Ocean in South Wellfleet." } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[var(--color-paper)] text-[var(--color-ink)]">
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="border-b border-[rgba(34,52,67,0.08)] bg-white/78 backdrop-blur md:hidden">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4">
        <a href="/" class="site-wordmark text-[2.5rem]">Cook's</a>
        <details class="mobile-nav">
          <summary class="list-none rounded-full border border-[rgba(34,52,67,0.12)] px-4 py-2 text-sm uppercase tracking-[0.24em] text-[var(--color-sea)]">
            Menu
          </summary>
          <nav class="mt-4 rounded-[1.5rem] border border-[rgba(34,52,67,0.1)] bg-white p-3 shadow-[0_20px_40px_rgba(34,52,67,0.08)]">
            <ul class="space-y-2">
              {
                navigationItems.map((item) => (
                  <li>
                    <a class:list={["mobile-nav-link", { active: isActive(item.href) }]} href={item.href}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </details>
      </div>
    </header>

    <div class="mx-auto grid min-h-screen max-w-7xl gap-8 px-5 py-6 md:grid-cols-[16rem_minmax(0,1fr)] md:px-8 md:py-8 xl:grid-cols-[18rem_minmax(0,1fr)]">
      <aside class="hidden md:block">
        <div class="sticky top-8 space-y-8 rounded-[2rem] border border-[rgba(34,52,67,0.12)] bg-[linear-gradient(180deg,rgba(255,255,255,0.9),rgba(244,239,229,0.9))] p-6 shadow-[0_20px_55px_rgba(34,52,67,0.08)]">
          <div class="space-y-2">
            <a href="/" class="inline-block">
              <span class="site-wordmark block">Cook's</span>
            </a>
            <p class="site-tagline">
              By the Ocean
            </p>
            <p class="text-sm leading-6 text-[var(--color-muted)]">
              South Wellfleet, Cape Cod. Heritage brochure with modern scaffolding.
            </p>
          </div>

          <nav aria-label="Primary">
            <ul class="space-y-2">
              {
                navigationItems.map((item) => (
                  <li>
                    <a class:list={["sidebar-link", { active: isActive(item.href) }]} href={item.href}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>

          <div class="rounded-[1.5rem] border border-[rgba(34,52,67,0.1)] bg-white/70 p-4">
            <p class="eyebrow">Current Facts</p>
            <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">
              Weekly rentals. Saturday to Saturday. Email remains the primary contact path.
            </p>
          </div>
        </div>
      </aside>

      <main id="main-content" class="pb-10">
        <div class="rounded-[2rem] border border-[rgba(34,52,67,0.1)] bg-[rgba(255,252,247,0.8)] p-6 shadow-[0_24px_70px_rgba(34,52,67,0.08)] backdrop-blur lg:p-8">
          <slot />
        </div>

        <footer class="mt-6 rounded-[1.75rem] border border-[rgba(34,52,67,0.08)] bg-white/70 px-6 py-5 text-sm text-[var(--color-muted)]">
          Cook's by the Ocean. South Wellfleet, MA. Current contact remains
          <a class="text-[var(--color-sea)] underline decoration-[rgba(84,114,136,0.35)] underline-offset-4" href="mailto:cooksbytheocean@gmail.com">
            cooksbytheocean@gmail.com
          </a>.
        </footer>
      </main>
    </div>
  </body>
</html>
